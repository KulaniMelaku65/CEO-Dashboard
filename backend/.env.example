PORT=4000
NODE_ENV=production

# SQLite database file path (relative to backend/, or absolute)
DB_PATH=../data/kifiya.db

# JWT secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# GROQ AI key — never goes to the browser
GROQ_KEY=your_groq_api_key_here

# Comma-separated allowed frontend origins (empty in production — same-origin)
ALLOWED_ORIGINS=

# ---- Business Central (OData) ----
# Accepted names (Vault may use either set):
#   BC_BASE  or BC_BASE_URL
#   BC_USER  or BC_USERNAME
#   BC_KEY   or BC_ACCESS_KEY
#   BC_COMPANY
BC_BASE=http://your-bc-host:7048/ERP/ODataV4
BC_COMPANY=YOUR COMPANY NAME
BC_USER=your_bc_web_service_user
BC_KEY=your_bc_web_service_key_here
BC_ALLOW_SELF_SIGNED=false

# Optional BC tuning
BC_BUDGET_NAME=20.1
BC_FY_START=2026-01-01

# ---- Automatic snapshot schedule ----
# Cron expression (UTC). Default: 04:00 & 10:00 UTC = 7 AM & 1 PM EAT
SNAPSHOT_CRON=0 4,10 * * *
# Set to false to disable scheduled pulls
# SNAPSHOT_SCHEDULER=false
# Pull from BC on every server start (default: enabled). Set to false to skip.
# SNAPSHOT_ON_STARTUP=false
