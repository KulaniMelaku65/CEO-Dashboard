PORT=4000
NODE_ENV=production

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kifiya_dashboard
DB_USER=postgres
DB_PASSWORD=your_strong_db_password_here
DB_SSL=false

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Service key — used by snapshot.js to POST snapshots to this server
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_KEY=replace_this_with_a_random_service_key

# GROQ AI key (never goes to the browser — stays server-side only)
GROQ_KEY=your_groq_api_key_here

# Comma-separated list of allowed frontend origins (for CORS)
# Leave empty if frontend is served by this same Express server (production)
ALLOWED_ORIGINS=
