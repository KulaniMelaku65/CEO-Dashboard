PORT=4000
NODE_ENV=production

# SQLite database file path (relative to project root, or absolute)
# The data/ folder is created automatically on first run
DB_PATH=../data/kifiya.db

# JWT secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Service key — used by snapshot.js to POST snapshots to this server
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_KEY=replace_this_with_a_random_service_key

# GROQ AI key — never goes to the browser, stays server-side only
GROQ_KEY=your_groq_api_key_here

# Comma-separated allowed frontend origins (leave empty in production —
# frontend is served by this same Express server so CORS is not needed)
ALLOWED_ORIGINS=
