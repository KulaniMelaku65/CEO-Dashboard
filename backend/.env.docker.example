# Copy to backend/.env before: docker compose up
# NEVER commit backend/.env or bake it into the image.

PORT=4000
NODE_ENV=production
DB_PATH=/app/data/kifiya.db

JWT_SECRET=generate_a_long_random_secret
GROQ_KEY=your_groq_api_key_here

# Empty when frontend is served by this same container
ALLOWED_ORIGINS=

# Business Central — container host must reach BC (VPN/host network)
BC_BASE=http://10.253.99.143:7048/ERP/ODataV4
BC_COMPANY=KIFIYA FINANCIAL TECHNOLOGY
BC_USER=your_bc_web_service_user
BC_KEY=your_bc_web_service_key
BC_ALLOW_SELF_SIGNED=false

BC_BUDGET_NAME=20.1
BC_FY_START=2026-01-01

SNAPSHOT_CRON=0 4,10 * * *
