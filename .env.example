# ---- snapshot.js .env — copy to .env and fill in values ----
# This file runs on the OFFICE PC that has Business Central access (VPN/LAN).
# The backend server has its own separate .env (backend/.env).

# Business Central OData
BC_BASE=http://10.253.99.143:7048/ERP/ODataV4
BC_COMPANY=KIFIYA FINANCIAL TECHNOLOGY
BC_USER=TestESS
BC_KEY=your_bc_web_service_key_here
BC_ALLOW_SELF_SIGNED=false

# Backend API — where snapshot.js POSTs the data it collects from BC
# This is the URL of the backend server (port 4000 by default)
BACKEND_URL=http://your-server-ip:4000

# Must match SERVICE_KEY in backend/.env exactly
SERVICE_KEY=your_service_key_here
