{
  "name": "kifiya-executive-dashboard",
  "version": "2.0.0",
  "private": true,
  "description": "Kifiya CEO Dashboard — monorepo root",
  "scripts": {
    "start":        "cd backend && node server.js",
    "dev:backend":  "cd backend && npx nodemon server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build":        "cd frontend && npm run build",
    "seed":         "cd backend && node seed-users.js",
    "setup":        "npm --prefix backend install && npm --prefix frontend install"
  }
}
